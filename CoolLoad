    Size = UDim2.new(0, 315, 0, 298)
}):Play()

-- ==========================================
-- TIMER SOUND: fade out & stop
-- ==========================================
task.delay(CONFIG.SOUND_STOP_WAIT, function()
    TweenService:Create(Sound, TweenInfo.new(1.2, Enum.EasingStyle.Sine), {
        Volume = 0
    }):Play()
    task.wait(1.25)
    Sound:Stop()
end)

-- ==========================================
-- TIMER UI: mengecil & hilang + blur off
-- ==========================================
task.delay(CONFIG.UI_HIDE_WAIT, function()
    dotAnimActive     = false
    loadingAnimActive = false

    -- Card mengecil
    local outroCard = TweenService:Create(MainFrame,
        TweenInfo.new(0.38, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0)
    })
    outroCard:Play()

    -- Background & blur fade out
    TweenService:Create(Background, TweenInfo.new(0.5, Enum.EasingStyle.Sine), {
        BackgroundTransparency = 1
    }):Play()
    TweenService:Create(BlurEffect, TweenInfo.new(0.55, Enum.EasingStyle.Sine), {
        Size = 0
    }):Play()

    outroCard.Completed:Connect(function()
        BlurEffect:Destroy()
        ScreenGui:Destroy()
        OnLoadingFinished()
    end)
end)
