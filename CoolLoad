-- ==========================================
-- ANIMASI DOTS & LOADING TEXT
-- ==========================================
local dotAnimActive     = true
local loadingAnimActive = true

task.spawn(function()
    local idx = 1
    while dotAnimActive do
        for i, d in ipairs(dots) do
            TweenService:Create(d, TweenInfo.new(0.15), {
                BackgroundTransparency = (i == idx) and 0 or 0.68,
                Size = (i == idx) and UDim2.new(0, 9, 0, 9) or UDim2.new(0, 5, 0, 5),
            }):Play()
        end
        idx = (idx % #dots) + 1
        task.wait(0.32)
    end
end)

task.spawn(function()
    while loadingAnimActive do
        TweenService:Create(LoadingLabel, TweenInfo.new(0.85, Enum.EasingStyle.Sine), {
            TextTransparency = 0.82
        }):Play()
        task.wait(0.90)
        TweenService:Create(LoadingLabel, TweenInfo.new(0.85, Enum.EasingStyle.Sine), {
            TextTransparency = 0
        }):Play()
        task.wait(0.90)
    end
end)

-- Glow pulse
task.spawn(function()
    while true do
        TweenService:Create(GlowFrame, TweenInfo.new(1.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            BackgroundTransparency = 0.72
        }):Play()
        task.wait(1.6)
        TweenService:Create(GlowFrame, TweenInfo.new(1.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            BackgroundTransparency = 0.90
        }):Play()
        task.wait(1.6)
    end
end)

